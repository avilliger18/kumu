{
  "name": "@kumu/backend",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "convex dev",
    "setup": "convex dev --until-success",
    "typecheck": "tsc --noEmit -p convex",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "author": "",
  "license": "ISC",
  "exports": {
    "./convex/_generated/api": {
      "types": "./convex/_generated/api.d.ts",
      "default": "./convex/_generated/api.js"
    },
    "./convex/_generated/dataModel": {
      "types": "./convex/_generated/dataModel.d.ts"
    },
    "./convex/_generated/server": {
      "types": "./convex/_generated/server.d.ts",
      "default": "./convex/_generated/server.js"
    }
  },
  "typesVersions": {
    "*": {
      "convex/_generated/api": [
        "./convex/_generated/api.d.ts"
      ],
      "convex/_generated/dataModel": [
        "./convex/_generated/dataModel.d.ts"
      ],
      "convex/_generated/server": [
        "./convex/_generated/server.d.ts"
      ]
    }
  },
  "dependencies": {
    "@auth/core": "0.37.0",
    "@convex-dev/auth": "^0.0.91",
    "convex": "^1.29.3",
    "openai": "^6.9.1",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "vitest": "^4.1.2"
  }
}
